{
  "name": "streamvix-lite",
  "version": "11.0.23",
  "description": "streamvix-lite addon con StreamingCommunity, Guardaserie, AnimeUnity, AnimeSaturn, AnimeWorld e Guardaflix",
  "main": "dist/addon.js",
  "packageManager": "pnpm@8.15.5",
  "scripts": {
    "build": "tsc && shx mkdir -p dist/config && shx cp src/config/*.json dist/config/",
    "start": "node dist/addon.js",
    "dev": "ts-node src/addon.ts"
  },
  "dependencies": {
    "axios": "^1.13.1",
    "axios-cookiejar-support": "^5.0.3",
    "cheerio": "^1.1.2",
    "express": "^4.18.2",
    "https-proxy-agent": "^7.0.6",
    "node-fetch": "^2.6.7",
    "socks-proxy-agent": "^8.0.5",
    "stremio-addon-sdk": "^1.6.10",
    "tough-cookie": "^4.1.4",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/express": "^4.17.17",
    "@types/node": "^20.19.24",
    "@types/node-fetch": "^2.6.2",
    "@types/tough-cookie": "^4.0.5",
    "shx": "^0.3.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
